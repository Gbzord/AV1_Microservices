{
  "name": "microservices-av1",
  "version": "1.0.0",
  "description": "AV Prática: Microserviços com Node.js, TypeScript, Fastify e Docker",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
